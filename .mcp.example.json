{
  "mcpServers": {
    "neocortica-scholar": {
      "command": "npx",
      "args": ["--prefix", "packages/scholar", "tsx", "packages/scholar/src/mcp_server.ts"],
      "env": {
        "MINERU_TOKEN": "your-mineru-token",
        "EMAIL": "your-email@example.com",
        "NEOCORTICA_CACHE": "/absolute/path/to/neocortica/.cache",
        "OPENAI_API_KEY": "your-openai-compatible-api-key",
        "OPENAI_BASE_URL": "https://openrouter.ai/api/v1",
        "OPENAI_MODEL": "openai/gpt-oss-120b"
      }
    },
    "neocortica-web": {
      "command": "npx",
      "args": ["--prefix", "packages/web", "tsx", "packages/web/src/mcp_server.ts"],
      "env": {
        "APIFY_TOKEN": "your-apify-token",
        "NEOCORTICA_CACHE": "/absolute/path/to/neocortica/.cache"
      }
    },
    "runpod": {
      "command": "npx",
      "args": ["-y", "@runpod/mcp-server@latest"],
      "env": {
        "RUNPOD_API_KEY": "your-runpod-api-key"
      }
    },
    "apify": {
      "command": "npx.cmd",
      "args": ["-y", "@apify/actors-mcp-server", "--tools", "fetch-actor-details,get-dataset-items,get-dataset-schema,marco.gullo/google-scholar-scraper,apify/rag-web-browser"],
      "env": {
        "APIFY_TOKEN": "your-apify-token"
      }
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@brave/brave-search-mcp-server@latest"],
      "env": {
        "BRAVE_API_KEY": "your-brave-api-key"
      }
    },
    "railway": {
      "command": "npx",
      "args": ["-y", "@railway/mcp-server@latest"],
      "env": {
        "RAILWAY_API_TOKEN": "your-railway-api-token"
      }
    },
    "neocortica-session": {
      "command": "echo",
      "args": ["credential-store-only"],
      "env": {
        "ANTHROPIC_BASE_URL": "https://api.anthropic.com",
        "ANTHROPIC_AUTH_TOKEN": "your-anthropic-api-key",
        "ANTHROPIC_MODEL": "claude-sonnet-4-6",
        "GITHUB_PAT": "your-github-pat",
        "HF_TOKEN": "your-huggingface-token"
      }
    }
  }
}
